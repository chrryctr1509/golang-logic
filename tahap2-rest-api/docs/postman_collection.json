                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"first_name\": \"John\",\n    \"last_name\": \"Doe\",\n    \"phone_number\": \"0811999901\",\n    \"address\": \"Jl. Sudirman No. 10\",\n    \"pin\": \"123456\"\n}"
                },
                "url": {
                    "raw": "{{baseUrl}}/register",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "register"
                    ]
                }
            }
        },
        {
            "name": "TC-03: Login (Success)",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "pm.test('TC-03: Login Success - Status 200', function() {",
                            "    pm.response.to.have.status(200);",
                            "});",
                            "pm.test('TC-03: Login Success - access_token present', function() {",
                            "    var jsonData = pm.response.json();",
                            "    pm.expect(jsonData.result).to.have.property('access_token');",
                            "    var token = jsonData.result.access_token;",
                            "    pm.expect(token).to.match(/^eyJ/);",
                            "    pm.collectionVariables.set('access_token', token);",
                            "});",
                            "pm.test('TC-03: Login Success - refresh_token present', function() {",
                            "    var jsonData = pm.response.json();",
                            "    pm.expect(jsonData.result).to.have.property('refresh_token');",
                            "    pm.expect(jsonData.result.refresh_token).to.match(/^eyJ/);",
                            "});"
                        ]
                    }
                }
            ],
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"phone_number\": \"0811999901\",\n    \"pin\": \"123456\"\n}"
                },
                "url": {
                    "raw": "{{baseUrl}}/login",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "login"
                    ]
                }
            }
