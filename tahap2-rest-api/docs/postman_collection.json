{
    "info": {
        "name": "tahap2-rest-api (Wallet API)",
        "description": "REST API Dompet Digital — 7 endpoints dengan JWT auth dan background worker",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:8080"
        },
        {
            "key": "access_token",
            "value": ""
        }
    ],
    "auth": {
        "type": "bearer",
        "bearer": [
            {
                "key": "token",
                "value": "{{access_token}}",
                "type": "string"
            }
        ]
    },
    "item": [
        {
            "name": "TC-01: Register (Success)",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "pm.test('TC-01: Register Success - Status 201', function() {",
                            "    pm.response.to.have.status(201);",
                            "});",
                            "pm.test('TC-01: Register Success - Response has status SUCCESS', function() {",
                            "    var jsonData = pm.response.json();",
                            "    pm.expect(jsonData.status).to.eql('SUCCESS');",
                            "});",
                            "pm.test('TC-01: Register Success - user_id is present', function() {",
                            "    var jsonData = pm.response.json();",
                            "    pm.expect(jsonData.result).to.have.property('user_id');",
                            "    pm.expect(jsonData.result.user_id).to.match(/^[0-9a-f-]{36}$/);",
                            "});",
                            "pm.test('TC-01: Register Success - phone_number correct', function() {",
                            "    var jsonData = pm.response.json();",
                            "    pm.expect(jsonData.result.phone_number).to.eql('0811999901');",
                            "});"
                        ]
                    }
                }
            ],
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"first_name\": \"John\",\n    \"last_name\": \"Doe\",\n    \"phone_number\": \"0811999901\",\n    \"address\": \"Jl. Sudirman No. 10\",\n    \"pin\": \"123456\"\n}"
                },
                "url": {
                    "raw": "{{baseUrl}}/register",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "register"
                    ]
                }
            }
        },
        {
            "name": "TC-02: Register - Duplicate Phone (FAIL Test)",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "pm.test('TC-02: Duplicate Phone - Status 400', function() {",
                            "    pm.response.to.have.status(400);",
                            "});",
                            "pm.test('TC-02: Duplicate Phone - Error message correct', function() {",
                            "    var jsonData = pm.response.json();",
                            "    pm.expect(jsonData.message).to.eql('Phone Number already registered');",
                            "});"
                        ]
                    }
                }
            ],
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
