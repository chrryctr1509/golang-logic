        {
            "name": "TC-05: Top Up (Success)",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "pm.test('TC-05: TopUp Success - Status 200', function() {",
                            "    pm.response.to.have.status(200);",
                            "});",
                            "pm.test('TC-05: TopUp Success - top_up_id present', function() {",
                            "    var jsonData = pm.response.json();",
                            "    pm.expect(jsonData.result).to.have.property('top_up_id');",
                            "    pm.expect(jsonData.result.top_up_id).to.match(/^[0-9a-f-]{36}$/);",
                            "});",
                            "pm.test('TC-05: TopUp Success - amount matches', function() {",
                            "    var jsonData = pm.response.json();",
                            "    pm.expect(jsonData.result.amount_top_up).to.eql(500000);",
                            "});",
                            "pm.test('TC-05: TopUp Success - balance_after > balance_before', function() {",
                            "    var jsonData = pm.response.json();",
                            "    pm.expect(jsonData.result.balance_after).to.be.above(jsonData.result.balance_before);",
                            "});"
