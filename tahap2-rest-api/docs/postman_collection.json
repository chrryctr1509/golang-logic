        {
            "name": "TC-09: Get Transactions (Dynamic Fields)",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "pm.test('TC-09: Transactions - Status 200', function() {",
                            "    pm.response.to.have.status(200);",
                            "});",
                            "pm.test('TC-09: Transactions - result is array', function() {",
                            "    var jsonData = pm.response.json();",
                            "    pm.expect(jsonData.result).to.be.an('array');",
                            "    pm.expect(jsonData.result.length).to.be.above(0);",
                            "});",
                            "pm.test('TC-09: Transactions - dynamic field names by kind', function() {",
                            "    var jsonData = pm.response.json();",
                            "    var tx = jsonData.result;",
                            "    // Check at least one of each field type exists",
                            "    var hasTopUp = tx.some(function(t) { return t.hasOwnProperty('top_up_id'); });",
                            "    var hasPayment = tx.some(function(t) { return t.hasOwnProperty('payment_id'); });",
                            "    var hasTransfer = tx.some(function(t) { return t.hasOwnProperty('transfer_id'); });",
                            "    pm.expect(hasTopUp || hasPayment || hasTransfer).to.be.true;",
                            "});"
                        ]
                    }
                }
            ],
            "request": {
                "method": "GET",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{access_token}}"
                    }
                ],
                "url": {
                    "raw": "{{baseUrl}}/api/v1/transactions",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "v1",
                        "transactions"
                    ]
                }
            }
